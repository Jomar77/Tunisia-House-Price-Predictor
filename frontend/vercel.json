{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://tunisia-house-price-predictor-production.up.railway.app/api/v1/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline';"
        }
      ]
    }
  ]
}
