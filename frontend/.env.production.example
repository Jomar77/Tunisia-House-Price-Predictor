# Vercel environment variable — set this in the Vercel project dashboard
# (Settings → Environment Variables → Production).
#
# Replace the placeholder with your Railway backend service URL.
# Railway exposes it as the public domain shown on the service's Settings page,
# e.g. https://tunisia-house-price-predictor-production.up.railway.app
# The /api/v1 prefix matches the FastAPI router prefix defined in
# backend/adapters/api/routes.py (APIRouter with prefix="/api/v1").
VITE_API_URL=https://<your-railway-service>.up.railway.app/api/v1
